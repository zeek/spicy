module Benchmark;

type Inner = unit {
    b: b"A";
};

public type UnitVectorSize = unit {
    length: uint64;
    inner: Inner[] &size=self.length;
    end_: b"BB";
};

public type UnitVectorLookahead = unit {
    length: uint64;
    inner: Inner[];
    end_: b"BB";
};

public type Regex = unit {
    length: uint64;
    data: /A*/;
    end_: b"BB";
};
