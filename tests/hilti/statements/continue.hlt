# FIXME(bbannier): this currently produces an infinite loop since we incorrectly deduce that a loop variable update in the body is not visible.
# @TEST-EXEC: timeout 30s ${HILTIC} -j %INPUT >output
# @TEST-EXEC: btest-diff output

module Foo {

import hilti;

for ( i in [1,2,3] ) {
    hilti::print(i);
    continue;
    hilti::print("X");
    }

while ( local int<64> i = 1; i != 4 ) {
    hilti::print(i);
    i = i + 1;
    continue;
    hilti::print("X");
    }

}
