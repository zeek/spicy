# @TEST-REQUIRES: which FileCheck
# @TEST-EXEC: hiltic -j %INPUT >output
# @TEST-EXEC: btest-diff output
# @TEST-EXEC: hiltic -c %INPUT -o output.cc
# @TEST-EXEC: FileCheck %INPUT <output.cc

module Foo {

import hilti;

const ONE = 1;

function int<64> g(int<64> i) {
    return i + 1;
}

function void f1(int<64> i) {
    # CHECK: switch
    switch ( i ) {
        # CHECK: case
        case ONE, ONE, 1: hilti::print("1A");
        # CHECK: case
        case 2,3,3,4: hilti::print("1B");
        # CHECK: case
        case 5: hilti::print("1C");
        # CHECK: default:
        default: hilti::print("1*");
    }
}

function void f1s(string s) {
    switch ( s ) {
        # CHECK: if (
        case "1A": hilti::print("1A");
        # CHECK: else if (
        case "1B1", "1B2", "1B3": hilti::print("1B");
        # CHECK: else if (
        case "1C": hilti::print("1C");
        # CHECK: else {
        default: hilti::print("1*");
    }
}

function void f2(int<64> i) {
    switch ( local auto x = g(i) ) {
        case 1: hilti::print("2A");
        case 2,3,4: hilti::print("2B");
        case 5: hilti::print("2C");
        case 4711:
            if (x == -2)
                hilti::print(x);
        default: hilti::print("2*");
    }
}

function void f3() {
    switch ( 1 ) {
        default: hilti::print("3*");
    }
}

function void f4() {
    # Will throw due to unhandled case.
    switch ( 1 ) {
        case 4711: hilti::print("unreachable case to prevent optimizing out the whole switch");
    }
}

f1(1);
f1(2);
f1(3);
f1(5);
f1(10);

f1s("1A");
f1s("1B2");
f1s("1C");
f1s("1D");

f2(1);
f2(2);
f2(3);
f2(5);
f2(10);

f3();
assert-exception f4();

global x = 3.0;
switch ( x ) {
    case 3: hilti::print("1T");
    case 4: hilti::print("1F");
}

global i = 1;

switch ( ++i ) {
    case 2: hilti::print("A");
    case 3: hilti::print("B");
    case 4: hilti::print("C");
}

}
