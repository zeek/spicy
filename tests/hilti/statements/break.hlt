# @TEST-EXEC: ${HILTIC} -j %INPUT >output
# @TEST-EXEC: btest-diff output

module Foo {

import hilti;

for ( i in [1,2,3] ) {
    hilti::print(i);
    break;
    }

while ( True ) {
    hilti::print(1);
    break;
    }


for ( i in [1,2,3] ) {
    switch ( i ) {
        case 2:
            break; # this breaks the loop!

        default: {}

        }

    hilti::print(i);
    }
}
