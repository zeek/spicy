# @TEST-DOC: Test boolean constant folding.

# @TEST-REQUIRES: which FileCheck
# @TEST-EXEC: hiltic -p %INPUT | FileCheck %INPUT
# @TEST-EXEC: hiltic -j %INPUT

module Test {

# CHECK: b1 = True
const b1 = (True || False);
# CHECK: b2 = False
const b2 = (True && False);

# CHECK-COUNT-4: assert True;
assert True && True;
assert (True && (False || (!False)));
assert b1 || b2;
assert !(b1 && b2);

}
