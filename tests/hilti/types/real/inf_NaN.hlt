# @TEST-EXEC: ${HILTIC} -j %INPUT >output
# @TEST-EXEC:  btest-diff output

module Foo {

import hilti;

global real one = 1.0;
global real neg_one = -1.0;
global zero = 0e0;
global real minus_zero = -0.0;
global real inf = one/zero;
global real minus_inf = neg_one/zero;
global real nan = zero/zero;

assert zero == minus_zero;
assert inf == inf;
assert minus_inf == minus_inf;
assert inf == - minus_inf;

# Note: NaN is always != anything
assert nan != nan;

hilti::print(zero);
hilti::print(minus_zero);
hilti::print(inf);
hilti::print(minus_inf);

# Note: NaN has a sign, doesn't mean anything
# (Removed, because depending on OS/compiler this may print as "nan" or "-nan".)
# hilti::print(nan);
# hilti::print(-nan);

}
