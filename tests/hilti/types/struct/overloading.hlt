# @TEST-EXEC: ${HILTIC} -j %INPUT >output
# @TEST-EXEC: btest-diff output

module Foo {

import hilti;

type T = struct {
    method string test();
    method string test(bool x);
    method string test(string x);
};

global T t;

method string T::test() { return "void"; }
# TODO: There are issues with infinite loops for overloads in these cases since There
# isn't a distinction between "empty params" and "should not be cleared"
# Avoid that by printing the values, but later remove those prints
method string T::test(bool x) {
    hilti::print(x);
    return "bool";
}
method string T::test(string x) {
    hilti::print(x);
    return "string";
}

hilti::print(t.test());
hilti::print(t.test(True));
hilti::print(t.test("x"));

}
