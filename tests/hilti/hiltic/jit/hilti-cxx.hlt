# @TEST-REQUIRES: using-build-directory
# @TEST-EXEC: sh run-with-cxx-wrapper.sh %INPUT >output
# @TEST-EXEC: btest-diff output
# @TEST-EXEC: btest-diff wrapper.output
# @TEST-EXEC-FAIL: HILTI_CXX=/does/not/exist hiltic -j %INPUT 2>error
# @TEST-EXEC: btest-diff error
#
# @TEST-DOC: Check that environment variable HILTI_CXX is used for JIT

module Foo {

import hilti;

hilti::print("Hello, world!");

}

@TEST-START-FILE run-with-cxx-wrapper.sh
#! /bin/sh
# Set HILTI_CXX to our wrapper and run hiltic with JIT.
if is-windows; then
    HILTI_CXX=$(cygpath -w "$(pwd)/cxx-wrapper.cmd")
    BUILD=$(cygpath -w "$($SCRIPTS/build-directory)")
else
    chmod +x cxx-wrapper
    HILTI_CXX=$(pwd)/cxx-wrapper
    BUILD=$($SCRIPTS/build-directory)
fi
export HILTI_CXX BUILD
hiltic -d -D jit -j "$1"
@TEST-END-FILE

@TEST-START-FILE cxx-wrapper
#! /bin/sh
echo "our wrapper ran!" >$(dirname $0)/wrapper.output
cxx=$(cat ${BUILD}/CMakeCache.txt | grep ^CMAKE_CXX_COMPILER: | cut -d = -f 2)
"${cxx}" "$@" >&2
@TEST-END-FILE

@TEST-START-FILE cxx-wrapper.cmd
@echo off
echo our wrapper ran!>"%~dp0wrapper.output"
for /f "usebackq tokens=1,* delims==" %%a in (`findstr /b "CMAKE_CXX_COMPILER:" "%BUILD%\CMakeCache.txt"`) do set "CXX=%%b"
"%CXX%" %*
@TEST-END-FILE
