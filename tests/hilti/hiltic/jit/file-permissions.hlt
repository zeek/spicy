# @TEST-DOC: Checks that HLTO files are created with proper permissions.
#
# @TEST-REQUIRES: is-windows
# @TEST-EXEC: hiltic -dj %INPUT -o test.hlto
# @TEST-EXEC: python check_perms.py test.hlto

module foo {}

@TEST-START-FILE check_perms.py
import os
import sys

hlto = sys.argv[1]

assert os.path.isfile(hlto)
assert os.access(hlto, os.R_OK | os.W_OK)

@TEST-END-FILE
